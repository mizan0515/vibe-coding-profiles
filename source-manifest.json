{
  "schema_version": 1,
  "intent": "public-safe source material for Codex and Claude Code vibe-coding profile packs",
  "source_policy": {
    "allowed_basis": "tracked repository templates and public docs only",
    "forbidden_basis": [
      "host-global profile folders",
      "local shell configuration files",
      "SSH material",
      "browser state folders",
      "cloud credentials",
      "private keys",
      "private material folders",
      "runtime logs",
      "private manager notes"
    ]
  },
  "shared": {
    "material": "profiles/shared-instructions.md",
    "tracked_sources": [
      "README.md",
      "profiles/shared-instructions.md",
      "templates/manager-report.ko.md",
      "templates/manager-report.en.md"
    ]
  },
  "codex": {
    "material": "profiles/codex-profile-source.md",
    "tracked_sources": [
      "runtime/codex-desktop/profile-template/prompts",
      "runtime/codex-desktop/profile-template/skills"
    ]
  },
  "claude": {
    "material": "profiles/claude-profile-source.md",
    "tracked_sources": [
      "runtime/claude-code/profile-template/prompts",
      "runtime/claude-code/profile-template/skills"
    ]
  },
  "validation": {
    "profile_pack": "scripts/Test-VibeCodingProfilePack.ps1",
    "templates": "scripts/Test-ProfileTemplates.ps1",
    "real_launch": "UNVERIFIED unless the current environment can launch the actual profile"
  }
}
